<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:id="@+id/headerControleur"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingStart="24dp">

        <TextView
            android:id="@+id/tvChatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messagerie"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLivreursBulles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerControleur"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/rvLivreursBulles"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Aujourd'hui — 10:30"
        android:textColor="#A0A0A0"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessagesControleur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutInputControleur"
        android:layout_below="@id/tvDate"
        android:padding="16dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/layoutInputControleur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_nav"
        android:background="#F8F9FA"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <EditText
            android:id="@+id/etMessageControleur"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="Écrire un message..."
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:textColor="#333333"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btnSendControleur"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_circle"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_controleur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>