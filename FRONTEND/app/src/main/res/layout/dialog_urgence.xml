<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F0F0">

    <RadioGroup
        android:id="@+id/rgRaisons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbAbsent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Client Absent\nPersonne à l'adresse"
            android:background="@drawable/bg_white_rounded"

            android:layout_marginBottom="10dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbRepondPas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ne répond pas\nInjoignable par téléphone"
            android:background="@drawable/bg_white_rounded"

            android:layout_marginBottom="10dp"/>

        <RadioButton
            android:id="@+id/rbAdresseIntrouvable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adresse introuvable\nCoordonnées fausses ou incomplètes"
            android:background="@drawable/bg_white_rounded"

            android:layout_marginBottom="10dp"/>

        <RadioButton
            android:id="@+id/rbRefus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Colis refusé\nLe client annule ou refuse de payer"
            android:background="@drawable/bg_white_rounded"

            android:layout_marginBottom="10dp"/>

        <RadioButton
            android:id="@+id/rbPaiement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Problème de paiement\nMontant exact indisponible, TPE en panne..."
            android:background="@drawable/bg_white_rounded"

            android:layout_marginBottom="15dp"/>

    </RadioGroup>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remarques (si non livrée)"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etRemarques"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Préciser la raison..."
        android:gravity="top|start"
        android:background="@drawable/bg_white_rounded"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnEnvoyerUrgence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Envoyer au Contrôleur"
        android:textColor="@android:color/white"
        android:backgroundTint="#2E7D32"
        android:padding="15dp"/>
</LinearLayout>